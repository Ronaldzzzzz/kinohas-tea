rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // 宣傳照：匿名管理員可上傳，公開可讀
    match /promotional-photos/{filename} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 彈窗圖片：登入可上傳，公開可讀
    match /popup-images/{filename} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 本店歷史照片：登入可上傳，公開可讀
    match /story-images/{filename} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 交通指引地圖圖片：登入可上傳，公開可讀
    match /directions-images/{filename} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 其他路徑：預設拒絕
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
